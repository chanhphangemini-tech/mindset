generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== SKILL PATHS & CONTENT ====================

model SkillPath {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  icon        String   // emoji icon
  color       String   // tailwind color class
  order       Int
  modules     Module[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Module {
  id          String   @id @default(cuid())
  title       String
  description String
  order       Int
  skillPathId String
  skillPath   SkillPath @relation(fields: [skillPathId], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Lesson {
  id          String   @id @default(cuid())
  title       String
  content     String   // markdown content
  keyTakeaways String  // JSON string - key takeaways
  order       Int
  moduleId    String
  module      Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quizzes     Quiz[]
  userProgress UserProgress[]
  
  // Estimated time to complete (minutes)
  estimatedMinutes Int @default(15)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Quiz {
  id          String   @id @default(cuid())
  type        String   // "mcq" | "open_ended" | "scenario"
  question    String
  options     String?  // JSON string for MCQ options
  correctAnswer String? // correct answer for MCQ
  explanation String   // explanation after answering
  order       Int
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==================== USER PROGRESS ====================

model UserProgress {
  id            String   @id @default(cuid())
  lessonId      String
  lesson        Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  completed     Boolean  @default(false)
  score         Int?     // quiz score 0-100
  quizAnswers   String?  // JSON string of answers
  xpEarned      Int      @default(0)
  completedAt   DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([lessonId])
}

model UserStats {
  id            String   @id @default(cuid())
  totalXP       Int      @default(0)
  level         Int      @default(1)
  currentStreak Int      @default(0)
  longestStreak Int      @default(0)
  lastStudyDate DateTime?
  lessonsCompleted Int   @default(0)
  quizzesTaken  Int      @default(0)
  totalTimeMinutes Int   @default(0)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DailyChallenge {
  id            String   @id @default(cuid())
  date          String   // YYYY-MM-DD
  skillPathId   String?
  title         String
  description   String
  challengeType String   // "scenario" | "quiz" | "reflection"
  content       String   // JSON string with challenge data
  completed     Boolean  @default(false)
  xpReward      Int      @default(50)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([date])
}

model Badge {
  id            String   @id @default(cuid())
  name          String
  description   String
  icon          String
  condition     String   // JSON string - condition to earn
  xpReward      Int      @default(0)
  earnedAt      DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model UserNote {
  id            String   @id @default(cuid())
  lessonId      String?
  title         String
  content       String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model StudySession {
  id            String   @id @default(cuid())
  lessonId      String?
  durationMinutes Int
  xpEarned      Int
  startedAt     DateTime @default(now())
  endedAt       DateTime?
}
